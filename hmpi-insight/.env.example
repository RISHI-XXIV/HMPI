# Omni Agent Configuration Template
# Copy this file to .env and fill in your values

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Alternative LLM APIs (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Vector Database Configuration
# For Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=omni-agent-knowledge

# For Weaviate (if using)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# Local Vector DB (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Database Configuration
DATABASE_URL=postgresql://omniagent:password@localhost:5432/omniagent
REDIS_URL=redis://localhost:6379/0
MONGODB_URL=mongodb://localhost:27017/omniagent

# Cloud Storage (optional)
# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=omni-agent-storage

# Azure
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_STORAGE_CONTAINER=omni-agent-storage

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_BUCKET=omni-agent-storage
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Monitoring and Analytics
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
METRICS_COLLECTION_INTERVAL=30

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=omni-agent@yourcompany.com

# Slack Integration (optional)
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_WEBHOOK_URL=your-slack-webhook-url

# IoT and Device Integration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# Learning Configuration
LEARNING_ENABLED=true
LEARNING_STRATEGY=hybrid
MODEL_SAVE_INTERVAL=100
EXPERIENCE_BUFFER_SIZE=1000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=true

# Development Settings
RELOAD_ON_CHANGE=true
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_PASSWORD=admin123

# Production Settings (override in production)
WORKERS=4
KEEP_ALIVE=65
TIMEOUT=30

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_INTERVAL=24
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/app/backups

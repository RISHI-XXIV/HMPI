# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/hmpi-insight

# JWT Secret
JWT_SECRET=hmpi_insight_secret_key_2024
JWT_EXPIRE=7d

# Client URL
CLIENT_URL=http://localhost:3000

# Email Configuration (Nodemailer) - Using defaults
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=test@example.com
EMAIL_PASS=testpassword

# SMS Configuration (Twilio) - Using defaults
TWILIO_ACCOUNT_SID=test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Maps API - Using defaults
GOOGLE_MAPS_API_KEY=test_google_maps_key

# OpenWeather API - Using defaults
OPENWEATHER_API_KEY=test_openweather_key

# Alert Thresholds (in mg/L)
LEAD_SAFE_LIMIT=0.01
ARSENIC_SAFE_LIMIT=0.01
MERCURY_SAFE_LIMIT=0.001
CADMIUM_SAFE_LIMIT=0.003
CHROMIUM_SAFE_LIMIT=0.05
NICKEL_SAFE_LIMIT=0.02

# Notification Settings
ENABLE_EMAIL_ALERTS=false
ENABLE_SMS_ALERTS=false
ALERT_CHECK_INTERVAL=3600000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=csv,xlsx,xls,json

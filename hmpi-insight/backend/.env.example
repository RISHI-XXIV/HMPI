# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/hmpi-insight

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Client URL
CLIENT_URL=http://localhost:3000

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenWeather API (for weather data in predictions)
OPENWEATHER_API_KEY=your_openweather_api_key

# Alert Thresholds (in mg/L)
LEAD_SAFE_LIMIT=0.01
ARSENIC_SAFE_LIMIT=0.01
MERCURY_SAFE_LIMIT=0.001
CADMIUM_SAFE_LIMIT=0.003
CHROMIUM_SAFE_LIMIT=0.05
NICKEL_SAFE_LIMIT=0.02

# Notification Settings
ENABLE_EMAIL_ALERTS=true
ENABLE_SMS_ALERTS=true
ALERT_CHECK_INTERVAL=3600000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=csv,xlsx,xls,json
